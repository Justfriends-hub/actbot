# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ─────────────────────────────────────────────────────────────────────────────
# FlashAza / Supabase Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Your Supabase project URL (no trailing slash)
# Found in: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase Service Role Key — gives read access to the history table
# Found in: Supabase Dashboard → Settings → API → service_role (secret)
# ⚠️  Keep this PRIVATE — never expose it in frontend code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your FlashAza account UID
# This is the value of the `uid` column in the FlashAza `users` table.
# Log in to FlashAza → open your profile → check the URL or ask your admin.
APP_USER_ID=6
